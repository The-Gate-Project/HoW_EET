IF
	True()
THEN
	RESPONSE #100
		CutSceneId("IWD_GEM")
		MultiPlayerSync()
		Wait(2)
		MoveViewPoint([943.839],VERY_FAST)
		EquipItemEx("IDRING91",0)  //  ÓŽŁŲÓ
		Kill("ICASARACHT")
		Wait(4)
		//SetVisualRange(0)
		ActionOverride("CUTSPY",DestroySelf())
		MoveViewObject(Player1,INSTANT)
		Wait(1)
		UnhideGUI()
		MultiPlayerSync()
		EndCutSceneMode()
END

